# Database
# Local: postgresql://user:password@localhost:5432/flowsync
# Neon DB: postgresql://user:pass@ep-host.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/flowsync"

# JWT Secrets
JWT_ACCESS_SECRET="your-super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-in-production"

# JWT Expiration
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
